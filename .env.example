# =============================================================================
# Core (required)
# =============================================================================

SUPABASE_URL=your-project-url
SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# AI — Chat Pool (at least one of AI_CHAT_* or GEMINI_API_KEY required)
# =============================================================================

# Each entry: provider:model:apiKey
# AI_CHAT_0=gemini:gemini-2.5-flash:AIzaSy...key1
# AI_CHAT_1=gemini:gemini-2.5-flash:AIzaSy...key2
# AI_CHAT_2=minimax:MiniMax-M1:eyJ...

# Fallback: used for chat if no AI_CHAT_* set; always used for embedding/parse
GEMINI_API_KEY=your-gemini-api-key

# Model overrides (optional — sensible defaults built in)
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_PARSE_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# =============================================================================
# Stripe
# =============================================================================

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_SEMESTER=price_...

# =============================================================================
# Upstash Redis
# =============================================================================

UPSTASH_REDIS_REST_URL=xx
UPSTASH_REDIS_REST_TOKEN=xx

# Management API (optional — admin dashboard stats)
# UPSTASH_MGMT_EMAIL=your-email@example.com
# UPSTASH_MGMT_API_KEY=your-management-api-key
# UPSTASH_DATABASE_ID=your-database-id

# =============================================================================
# Rate Limiting & Quotas (all optional — sensible defaults built in)
# =============================================================================

# Set ENABLE_RATELIMIT=true to enable in dev (always on in production)
# ENABLE_RATELIMIT=true

# DDoS proxy — applies to ALL requests (pages, API, RSC)
# RATE_LIMIT_PUBLIC_REQUESTS=60
# RATE_LIMIT_PUBLIC_WINDOW="60 s"
# RATE_LIMIT_PRO_REQUESTS=100
# RATE_LIMIT_PRO_WINDOW="10 s"

# LLM quota — daily + per-window (chat/LLM API only)
# LLM_LIMIT_DAILY_FREE=10
# LLM_LIMIT_DAILY_PRO=30
# RATE_LIMIT_LLM_FREE_REQUESTS=3
# RATE_LIMIT_LLM_FREE_WINDOW="60 s"
# RATE_LIMIT_LLM_PRO_REQUESTS=60
# RATE_LIMIT_LLM_PRO_WINDOW="60 s"

# =============================================================================
# RAG Pipeline (all optional — sensible defaults built in)
# =============================================================================

# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200
# RAG_EMBEDDING_DIM=768
# RAG_MATCH_THRESHOLD=0.5
# RAG_MATCH_COUNT=5
# RAG_RRF_K=60
# RAG_RERANK_ENABLED=true
# RAG_RERANK_MULTIPLIER=2

# =============================================================================
# Misc
# =============================================================================

# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
